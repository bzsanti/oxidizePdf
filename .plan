**Implementation** en `oxidize-pdf-core/src/parser/document.rs`:
```rust
impl PdfDocument<std::fs::File> {
    pub fn open<P: AsRef<std::path::Path>>(path: P) -> ParseResult<Self> {
        PdfReader::open_document(path)
    }
}
```

