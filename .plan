#### Ciclo 1.3 — Tests complementarios del merge policy

Anadir en `hybrid_chunking_v2_test.rs`:

```rust
#[test]
fn test_same_type_only_policy_preserves_legacy_behavior() {
    // Con SameTypeOnly, Paragraph+ListItem no se mergean
    let elements = vec![
        para_with_heading("Intro.", 0, 700.0, None),
        list_item_with_heading("- Item.", 0, 680.0, None),
    ];
    let chunker = HybridChunker::new(HybridChunkConfig {
        max_tokens: 512,
        merge_adjacent: true,
        merge_policy: MergePolicy::SameTypeOnly,
        ..Default::default()
    });
    let chunks = chunker.chunk(&elements);
    assert_eq!(chunks.len(), 2);
}

#[test]
fn test_title_never_merges_with_adjacent_paragraph() {
    let elements = vec![
        title_elem("Chapter", 0, 750.0),
        para_with_heading("Content.", 0, 700.0, Some("Chapter")),
    ];
    let chunker = HybridChunker::new(HybridChunkConfig {
        max_tokens: 512,
        merge_adjacent: true,
        merge_policy: MergePolicy::AnyInlineContent,
        ..Default::default()
    });
    let chunks = chunker.chunk(&elements);
    // Title debe ser chunk separado siempre
    assert!(chunks.iter().any(|c| c.elements().iter().any(|e| matches!(e, Element::Title(_)))));
    assert!(chunks.len() >= 2);
}

#[test]
fn test_table_never_merges_with_adjacent_paragraph() {
    let table = make_small_table();  // helper que crea Table con 3 rows
    let elements = vec![
        para_with_heading("Before table.", 0, 750.0, None),
        table,
        para_with_heading("After table.", 0, 200.0, None),
    ];
    let chunker = HybridChunker::new(HybridChunkConfig {
        max_tokens: 512,
        merge_adjacent: true,
        merge_policy: MergePolicy::AnyInlineContent,
        ..Default::default()
    });
    let chunks = chunker.chunk(&elements);
    // Table debe ir sola
    let table_chunks: Vec<_> = chunks.iter()
        .filter(|c| c.elements().iter().any(|e| matches!(e, Element::Table(_))))
        .collect();
    assert_eq!(table_chunks.len(), 1);
    assert_eq!(table_chunks[0].elements().len(), 1);
}
```

