#### Ciclo 1.2 — Relaciones next/prev (sibling navigation)

Test a escribir en `element_graph_test.rs`:
```rust
#[test]
fn test_graph_next_prev_chain() {
    let elements = vec![
        make_paragraph("First"),
        make_paragraph("Second"),
        make_paragraph("Third"),
    ];
    let graph = ElementGraph::build(&elements);
    assert_eq!(graph.next_of(0), Some(1));
    assert_eq!(graph.next_of(1), Some(2));
    assert!(graph.next_of(2).is_none());
    assert!(graph.prev_of(0).is_none());
    assert_eq!(graph.prev_of(1), Some(0));
    assert_eq!(graph.prev_of(2), Some(1));
}
```

Implementación: llenar `next[i] = Some(i+1)` y `prev[i] = Some(i-1)` en `build()`.
Estimación: 10 min.

---

#### Ciclo 1.3 — Relaciones parent/child basadas en parent_heading

Un elemento es "hijo" de un Title si su `parent_heading` coincide con el texto del Title,
y el Title aparece antes en el slice.

Test a escribir en `element_graph_test.rs`:
```rust
#[test]
fn test_graph_parent_child_simple() {
    // Simula lo que produce Partitioner: title tiene parent_heading = su propio texto,
    // paragraphs tienen parent_heading = texto del título anterior.
    let elements = vec![
        make_title_with_heading("Introduction", "Introduction"),
        make_para_with_heading("Para 1", "Introduction"),
        make_para_with_heading("Para 2", "Introduction"),
    ];
    let graph = ElementGraph::build(&elements);

    // El título es padre de los dos párrafos
    assert_eq!(graph.children_of(0), &[1, 2]);
    assert_eq!(graph.parent_of(1), Some(0));
    assert_eq!(graph.parent_of(2), Some(0));
    // El título en sí no tiene padre
    assert!(graph.parent_of(0).is_none());
}

#[test]
fn test_graph_parent_switches_on_new_title() {
    let elements = vec![
        make_title_with_heading("Chapter 1", "Chapter 1"),
        make_para_with_heading("Para A", "Chapter 1"),
        make_title_with_heading("Chapter 2", "Chapter 2"),
        make_para_with_heading("Para B", "Chapter 2"),
    ];
    let graph = ElementGraph::build(&elements);

    assert_eq!(graph.children_of(0), &[1]);    // Ch1 -> [Para A]
    assert_eq!(graph.children_of(2), &[3]);    // Ch2 -> [Para B]
    assert_eq!(graph.parent_of(1), Some(0));   // Para A -> Ch1
    assert_eq!(graph.parent_of(3), Some(2));   // Para B -> Ch2
}

#[test]
fn test_graph_no_parent_heading_means_no_parent() {
    let elements = vec![
        make_para_with_heading("Preamble", ""),  // parent_heading = None
        make_title_with_heading("Intro", "Intro"),
        make_para_with_heading("Body", "Intro"),
    ];
    let graph = ElementGraph::build(&elements);

    assert!(graph.parent_of(0).is_none());  // Preamble no tiene padre
    assert_eq!(graph.parent_of(2), Some(1));
}
```

Implementación en `ElementGraph::build`:
1. Construir mapa `heading_text -> index` para todos los `Element::Title`.
2. Para cada elemento con `parent_heading = Some(text)`:
   - Buscar el título más reciente con ese texto.
   - Asignar `parent[i] = Some(title_idx)`.
   - Añadir `i` a `children[title_idx]`.

Estimación: 25 min.

