### Fase 4: Tests de integración end-to-end

**Archivo**: `oxidize-pdf-core/tests/element_relationships_advanced_test.rs` (nuevo)

#### Ciclo 4.1 — Navegación completa de un documento artificial

```rust
#[test]
fn test_full_navigation_three_sections() {
    let fragments = vec![
        frag("Preamble text here.", 50.0, 800.0, 12.0),
        frag("Chapter One", 50.0, 750.0, 24.0),
        frag("Content of chapter one.", 50.0, 700.0, 12.0),
        frag("More content of chapter one.", 50.0, 680.0, 12.0),
        frag("Chapter Two", 50.0, 630.0, 24.0),
        frag("Content of chapter two.", 50.0, 580.0, 12.0),
        frag("Chapter Three", 50.0, 530.0, 24.0),
    ];
    let elements = Partitioner::new(PartitionConfig::default())
        .partition_fragments(&fragments, 0, 842.0);
    let graph = ElementGraph::build(&elements);

    let sections = graph.top_level_sections();
    // Debe haber exactamente 3 secciones
    assert_eq!(sections.len(), 3);

    let ch1_idx = sections[0];
    let ch1_children = graph.elements_in_section(ch1_idx);
    assert_eq!(ch1_children.len(), 2);  // 2 párrafos en Chapter One

    let ch3_idx = sections[2];
    let ch3_children = graph.elements_in_section(ch3_idx);
    assert_eq!(ch3_children.len(), 0);  // Chapter Three no tiene hijos

    // Navegación next/prev entre secciones
    assert_eq!(graph.next_of(ch1_idx), Some(ch1_idx + 1));  // siguiente elemento
}
```

#### Ciclo 4.2 — Verificar que la API pública de Vec<Element> no cambia

```rust
#[test]
fn test_partition_api_unchanged() {
    // Este test verifica backward compatibility:
    // partition() sigue devolviendo Vec<Element> sin cambios.
    let fragments = vec![
        frag("Title", 50.0, 750.0, 24.0),
        frag("Body.", 50.0, 700.0, 12.0),
    ];
    let elements: Vec<oxidize_pdf::pipeline::Element> =
        Partitioner::new(PartitionConfig::default())
            .partition_fragments(&fragments, 0, 842.0);

    // La API original funciona sin graph
    assert!(!elements.is_empty());
    assert_eq!(
        elements[0].metadata().parent_heading.as_deref(),
        Some("Title")
    );
}
```

Estimación: 15 min.

